{
  "manifest_version": 3,
  "name": "LinkedMail AI - Cold Email Generator",
  "version": "1.0.0",
  "description": "Generate personalized cold emails from any LinkedIn profile in one click.",
  "permissions": ["activeTab", "storage", "scripting", "identity"],
  "oauth2": {
    "client_id": "730317401372-lgv9b4gmfmfmph0na13maid8hd1imla0.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "host_permissions": ["https://www.linkedin.com/*", "https://modest-wonder-production-84f9.up.railway.app/*", "https://www.googleapis.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
